# Server bind address. Serves REST (/categorize, /health) at the root and the MCP
# streamable-HTTP endpoint at /mcp.
MCP_HOST=127.0.0.1
MCP_PORT=8090

# Ollama connection (shared with the Go backend).
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
# qwen3:1.7b is small enough to run on CPU; change if you have a bigger one pulled.
OLLAMA_MODEL=qwen3:1.7b
# Optional override; falls back to OLLAMA_MODEL when empty.
CATEGORIZE_MODEL=qwen3:1.7b
CATEGORIZE_NUM_PREDICT=256
CATEGORIZE_KEEP_ALIVE=10m

# Two-model combo: a fast model drives the tool-calling loop, a stronger model makes
# the final decision. Both fall back to CATEGORIZE_MODEL if unset (single-model setup).
CATEGORIZE_CHAT_MODEL=qwen3:1.7b
CATEGORIZE_DECIDE_MODEL=qwen3:4b

# Agent budgets. Per-product wall-clock cap in seconds (the 5–10 min ceiling),
# max tool-calling turns before forcing a decision, and how many lookalike products
# search_similar_products returns.
CATEGORIZE_DEADLINE=600
CATEGORIZE_MAX_ITERS=6
CATEGORIZE_SIMILAR_LIMIT=5

# Postgres. Either set DATABASE_URL, or the DB_* parts below.
# DATABASE_URL=postgresql://user:pass@localhost:5432/fintrack?sslmode=disable
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=fintrack

# ---------------------------------------------------------------------------
# docker-compose only (the bundle). Ignored when running the app directly.
# ---------------------------------------------------------------------------
# Image to run/publish and its tag (defaults: mmarci96/categorizer-mcp:latest).
# IMAGE=mmarci96/categorizer-mcp
# TAG=latest
# Models the one-shot puller fetches into the ollama volume (space-separated).
CATEGORIZE_PULL_MODELS=qwen3:1.7b qwen3:4b
# REQUIRED for the bundle: how the categorizer reaches your backend's Postgres.
# Use a host/IP reachable from inside the container (not "localhost").
# DATABASE_URL=postgresql://fin-track:secure_password@your-db-host:5432/fin-track-db?sslmode=disable
